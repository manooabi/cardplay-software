{% extends 'base.html.twig' %}

{% block title %}Edit Software Version{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
  .sv-page { 
    padding: 2rem 0; 
    font-family: system-ui, sans-serif; 
    max-width: 700px; 
    margin: auto; 
  }
  .sv-header { 
    display: flex; 
    align-items: center; 
    justify-content: space-between; 
    margin-bottom: 1.5rem; 
  }
  .sv-title { 
    font-size: 20px; 
    font-weight: 600; 
    color: #1a1a18; 
  }
  .btn-back, .btn-delete { 
    display: inline-flex; 
    align-items: center; 
    gap: 6px; 
    padding: 7px 14px; 
    font-size: 13px; 
    font-weight: 500; 
    border-radius: 8px; 
    cursor: pointer; 
    text-decoration: none; 
    border: none; 
  }
  .btn-back { 
    background: #1a1a18; color: #fff; 
  }
  .btn-back:hover { opacity: 0.85; }
  .btn-delete { 
    background: #dc3545; color: #fff; 
  }
  .btn-delete:hover { opacity: 0.85; }

  .form-card { 
    background: #fff; 
    border: 0.5px solid #e0dfd8; 
    border-radius: 12px; 
    padding: 2rem; 
    box-shadow: 0 2px 6px rgba(0,0,0,0.05);
    margin-bottom: 1.5rem;
  }

  form button { 
    padding: 8px 16px; 
    font-size: 13px; 
    font-weight: 500; 
    border-radius: 8px; 
    cursor: pointer; 
    border: none; 
    background: #1a1a18; 
    color: #fff; 
  }
  form button:hover { 
    opacity: 0.85; 
  }

  .sv-actions { 
    display: flex; 
    gap: 10px; 
    margin-top: 1rem; 
  }

  @media (max-width: 768px) {
    .sv-page { padding: 1rem; }
    .sv-actions { flex-direction: column; }
    form button { width: 100%; }
  }
</style>
{% endblock %}

{% block body %}
<div class="sv-page">
  <div class="sv-header">
    <span class="sv-title">Edit Software Version</span>
  </div>

  <div class="form-card">
    {{ include('admin_software_version/_form.html.twig', {'button_label': 'Update'}) }}
    
    <div class="sv-actions">
      <a href="{{ path('app_admin_software_version_index') }}" class="btn-back">Back to List</a>
      {{ include('admin_software_version/_delete_form.html.twig', { 'attr': { 'class': 'btn-delete' } }) }}
    </div>
  </div>
</div>
{% endblock %}